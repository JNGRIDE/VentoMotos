rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isManager() {
      return isAuthenticated() && getUserData().role == 'Manager';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Rules for collections
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isManager();
    }

    match /sales/{saleId} {
      allow read: if isManager() || (isAuthenticated() && resource.data.salespersonId == request.auth.uid);
      allow create: if isManager() || (isAuthenticated() && request.resource.data.salespersonId == request.auth.uid);
      allow update, delete: if isManager();
    }

    match /prospects/{prospectId} {
      allow read: if isManager() || (isAuthenticated() && resource.data.salespersonId == request.auth.uid);
      allow write: if isManager() || (isAuthenticated() && request.resource.data.salespersonId == request.auth.uid);
    }

    match /inventory/{motorcycleId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated();
      allow create, delete: if isManager();
    }

    match /sprints/{sprintId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isManager();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    // REGLA ACTUALIZADA: Centro de Utilidades (v1.0.2 - Auto-deploy trigger)
    match /utilities/{utilityId} {
      // Todo el equipo puede ver los recursos
      allow read: if isAuthenticated();
      // Solo el Manager puede administrar el catálogo
      allow write: if isManager();
    }
  }
}