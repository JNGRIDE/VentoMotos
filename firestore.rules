rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isManager() {
      // Validamos que el usuario exista y tenga el rol de Manager
      return isAuthenticated() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Manager';
    }

    match /users/{userId} {
      // Cualquier usuario autenticado puede leer perfiles
      allow read: if isAuthenticated();
      // Solo el dueño o un manager puede editar un perfil
      allow write: if isOwner(userId) || isManager();
    }

    match /sales/{saleId} {
      allow read: if isManager() || (isAuthenticated() && resource.data.salespersonId == request.auth.uid);
      allow create: if isManager() || (isAuthenticated() && request.resource.data.salespersonId == request.auth.uid);
      allow update, delete: if isManager();
    }

    match /prospects/{prospectId} {
      allow read: if isManager() || (isAuthenticated() && resource.data.salespersonId == request.auth.uid);
      allow write: if isManager() || (isAuthenticated() && request.resource.data.salespersonId == request.auth.uid);
    }

    match /inventory/{motorcycleId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated();
      allow create, delete: if isManager();
    }

    match /sprints/{sprintId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isManager();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isManager();
    }

    match /utilities/{utilityId} {
      // Todos los vendedores y managers pueden ver los links
      allow read: if isAuthenticated();
      // Solo el Manager puede crear, editar o borrar
      allow write: if isManager();
    }
  }
}